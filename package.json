{
  "name": "moyeoplay",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:pages": "PAGES_BASE_PATH=/moyeoplay/ SITE_URL=https://dubeeubbee.github.io/moyeoplay/ npm run build",
    "verify:dist": "node scripts/verify-dist.mjs",
    "preview": "vite preview",
    "preview:pages": "PAGES_BASE_PATH=/moyeoplay/ SITE_URL=https://dubeeubbee.github.io/moyeoplay/ vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test:e2e:prod",
    "test:e2e:dev": "E2E_MODE=dev playwright test",
    "test:e2e:prod": "npm run build:pages && npm run test:e2e:prod:run",
    "test:e2e:prod:run": "E2E_MODE=prod E2E_BASE_PATH=/moyeoplay/ playwright test",
    "test:e2e:live": "E2E_MODE=live playwright test tests/e2e/live.spec.ts --project=chromium-mobile",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
